using Microsoft.AspNetCore.Mvc;
using Recruit_Pro.Models;
using System.Data;
using MySqlConnector;

namespace Recruit_Pro.Controllers
{
    public class PositionController : Controller
    {
        public IActionResult Index()
        {
            List<Position> positionList = new List<Position>();
            string query = "SELECT * FROM job_position";
            DataTable dt = SqlHelper.ExecuteQuery(query);
            foreach (DataRow row in dt.Rows)
            {
                positionList.Add(new Position
                {
                    position_id = Convert.ToInt32(row["position_id"]),
                    title = row["title"].ToString(),
                    department = row["department"].ToString(),
                    description = (row["description"] == DBNull.Value) ? "" : row["description"].ToString(),
                    gender = (row["gender"] == DBNull.Value) ? null : Convert.ToInt32(row["gender"].ToString()),
                    responsibilities = (row["responsibilities"] == DBNull.Value) ? "" : row["responsibilities"].ToString(),
                    domicile = (row["domicile"] == DBNull.Value) ? "" : row["domicile"].ToString(),
                    starting_salary = (row["starting_salary"] == DBNull.Value) ? null : Convert.ToInt32(row["starting_salary"].ToString()),
                    maximum_salary = (row["maximum_salary"] == DBNull.Value) ? null : Convert.ToInt32(row["maximum_salary"].ToString()),
                    scale = (row["scale"] == DBNull.Value) ? "" : row["scale"].ToString(),
                    minimum_age = (row["minimum_age"] == DBNull.Value) ? null : Convert.ToInt32(row["minimum_age"].ToString()),
                    maximum_age = (row["maximum_age"] == DBNull.Value) ? null : Convert.ToInt32(row["maximum_age"].ToString()),
                    status = (row["status"] == DBNull.Value) ? 0 : Convert.ToInt32(row["status"].ToString()),
                    remarks = (row["remarks"] == DBNull.Value) ? "" : row["remarks"].ToString()
                });
            }
            return View(positionList);
        }

        // GET: Position/Create
        public IActionResult Create()
        {
            PopulateLookups();
            return View("PositionForm", new Position());
        }

        // POST: Position/Create
        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Create(Position model)
        {
            if (!ModelState.IsValid)
            {
                PopulateLookups();
                return View("PositionForm", model);
            }

            string query = @"INSERT INTO job_position
                                (title, department, description, gender, responsibilities, domicile, starting_salary, maximum_salary, scale, minimum_age, maximum_age, status, remarks)
                                VALUES
                                (@title, @department, @description, @gender, @responsibilities, @domicile, @starting_salary, @maximum_salary, @scale, @minimum_age, @maximum_age, @status, @remarks);";

            MySqlParameter[] parameters = new MySqlParameter[]
            {
                new MySqlParameter("@title", model.title ?? (object)DBNull.Value),
                new MySqlParameter("@department", model.department ?? (object)DBNull.Value),
                new MySqlParameter("@description", string.IsNullOrEmpty(model.description) ? (object)DBNull.Value : model.description),
                new MySqlParameter("@gender", model.gender.HasValue ? (object)model.gender.Value : (object)DBNull.Value),
                new MySqlParameter("@responsibilities", string.IsNullOrEmpty(model.responsibilities) ? (object)DBNull.Value : model.responsibilities),
                new MySqlParameter("@domicile", string.IsNullOrEmpty(model.domicile) ? (object)DBNull.Value : model.domicile),
                new MySqlParameter("@starting_salary", model.starting_salary.HasValue ? (object)model.starting_salary.Value : (object)DBNull.Value),
                new MySqlParameter("@maximum_salary", model.maximum_salary.HasValue ? (object)model.maximum_salary.Value : (object)DBNull.Value),
                new MySqlParameter("@scale", string.IsNullOrEmpty(model.scale) ? (object)DBNull.Value : model.scale),
                new MySqlParameter("@minimum_age", model.minimum_age.HasValue ? (object)model.minimum_age.Value : (object)DBNull.Value),
                new MySqlParameter("@maximum_age", model.maximum_age.HasValue ? (object)model.maximum_age.Value : (object)DBNull.Value),
                new MySqlParameter("@status", model.status),
                new MySqlParameter("@remarks", string.IsNullOrEmpty(model.remarks) ? (object)DBNull.Value : model.remarks)
            };

            try
            {
                SqlHelper.ExecuteNonQuery(query, parameters);
            }
            catch (Exception ex)
            {
                // Log and return form with error
                Console.WriteLine($"Error creating position: {ex.Message}");
                ModelState.AddModelError(string.Empty, "An error occurred while saving the position.");
                PopulateLookups();
                return View("PositionForm", model);
            }

            return RedirectToAction("Index");
        }

        // GET: Position/Edit/5
        public IActionResult Edit(int id)
        {
            Position model = GetPositionById(id);
            if (model == null)
            {
                return NotFound();
            }
            PopulateLookups();
            return View("PositionForm", model);
        }

        // POST: Position/Edit/5
        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Edit(Position model)
        {
            if (!ModelState.IsValid)
            {
                PopulateLookups();
                return View("PositionForm", model);
            }

            string query = @"UPDATE job_position SET
                                title = @title,
                                department = @department,
                                description = @description,
                                gender = @gender,
                                responsibilities = @responsibilities,
                                domicile = @domicile,
                                starting_salary = @starting_salary,
                                maximum_salary = @maximum_salary,
                                scale = @scale,
                                minimum_age = @minimum_age,
                                maximum_age = @maximum_age,
                                status = @status,
                                remarks = @remarks
                                WHERE position_id = @position_id";

            MySqlParameter[] parameters = new MySqlParameter[]
            {
                new MySqlParameter("@title", model.title ?? (object)DBNull.Value),
                new MySqlParameter("@department", model.department ?? (object)DBNull.Value),
                new MySqlParameter("@description", string.IsNullOrEmpty(model.description) ? (object)DBNull.Value : model.description),
                new MySqlParameter("@gender", model.gender.HasValue ? (object)model.gender.Value : (object)DBNull.Value),
                new MySqlParameter("@responsibilities", string.IsNullOrEmpty(model.responsibilities) ? (object)DBNull.Value : model.responsibilities),
                new MySqlParameter("@domicile", string.IsNullOrEmpty(model.domicile) ? (object)DBNull.Value : model.domicile),
                new MySqlParameter("@starting_salary", model.starting_salary.HasValue ? (object)model.starting_salary.Value : (object)DBNull.Value),
                new MySqlParameter("@maximum_salary", model.maximum_salary.HasValue ? (object)model.maximum_salary.Value : (object)DBNull.Value),
                new MySqlParameter("@scale", string.IsNullOrEmpty(model.scale) ? (object)DBNull.Value : model.scale),
                new MySqlParameter("@minimum_age", model.minimum_age.HasValue ? (object)model.minimum_age.Value : (object)DBNull.Value),
                new MySqlParameter("@maximum_age", model.maximum_age.HasValue ? (object)model.maximum_age.Value : (object)DBNull.Value),
                new MySqlParameter("@status", model.status),
                new MySqlParameter("@remarks", string.IsNullOrEmpty(model.remarks) ? (object)DBNull.Value : model.remarks),
                new MySqlParameter("@position_id", model.position_id)
            };

            try
            {
                SqlHelper.ExecuteNonQuery(query, parameters);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating position {model.position_id}: {ex.Message}");
                ModelState.AddModelError(string.Empty, "An error occurred while updating the position.");
                PopulateLookups();
                return View("PositionForm", model);
            }

            return RedirectToAction("Index");
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Delete(int id)
        {
            string query = "DELETE FROM job_position WHERE position_id = @position_id;";
            MySqlParameter[] parameters = new MySqlParameter[]
            {
                new MySqlParameter("@position_id", id)
            };
            try
            {
                SqlHelper.ExecuteNonQuery(query, parameters);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting position with ID {id}: {ex.Message}");
            }
            return RedirectToAction("Index");
        }

        // Helper: load a single position
        private Position GetPositionById(int id)
        {
            string query = "SELECT * FROM job_position WHERE position_id = @position_id";
            MySqlParameter[] parameters = new MySqlParameter[]
            {
                new MySqlParameter("@position_id", id)
            };
            DataTable dt = SqlHelper.ExecuteQuery(query, parameters);
            if (dt.Rows.Count == 0) return null;
            DataRow row = dt.Rows[0];
            return new Position
            {
                position_id = Convert.ToInt32(row["position_id"]),
                title = row["title"].ToString(),
                department = row["department"].ToString(),
                description = (row["description"] == DBNull.Value) ? "" : row["description"].ToString(),
                gender = (row["gender"] == DBNull.Value) ? null : Convert.ToInt32(row["gender"].ToString()),
                responsibilities = (row["responsibilities"] == DBNull.Value) ? "" : row["responsibilities"].ToString(),
                domicile = (row["domicile"] == DBNull.Value) ? "" : row["domicile"].ToString(),
                starting_salary = (row["starting_salary"] == DBNull.Value) ? null : Convert.ToInt32(row["starting_salary"].ToString()),
                maximum_salary = (row["maximum_salary"] == DBNull.Value) ? null : Convert.ToInt32(row["maximum_salary"].ToString()),
                scale = (row["scale"] == DBNull.Value) ? "" : row["scale"].ToString(),
                minimum_age = (row["minimum_age"] == DBNull.Value) ? null : Convert.ToInt32(row["minimum_age"].ToString()),
                maximum_age = (row["maximum_age"] == DBNull.Value) ? null : Convert.ToInt32(row["maximum_age"].ToString()),
                status = (row["status"] == DBNull.Value) ? 0 : Convert.ToInt32(row["status"].ToString()),
                remarks = (row["remarks"] == DBNull.Value) ? "" : row["remarks"].ToString()
            };
        }

        // Helper: populate ViewBag with lookup lists
        private void PopulateLookups()
        {
            var genders = GetLookupsByType("gender");
            var statuses = GetLookupsByType("status");

            ViewBag.Genders = genders;
            ViewBag.Statuses = statuses;

            // Create SelectList objects for use in Razor without complex inline expressions
            ViewBag.GendersSelectList = new Microsoft.AspNetCore.Mvc.Rendering.SelectList(genders, "lookup_id", "lookup_value");
            ViewBag.StatusesSelectList = new Microsoft.AspNetCore.Mvc.Rendering.SelectList(statuses, "lookup_id", "lookup_value");
        }

        private List<Lookup> GetLookupsByType(string type)
        {
            List<Lookup> list = new List<Lookup>();
            string query = "SELECT * FROM lookup WHERE LOWER(lookup_type) = @type";
            MySqlParameter[] parameters = new MySqlParameter[]
            {
                new MySqlParameter("@type", type.ToLower())
            };
            DataTable dt = SqlHelper.ExecuteQuery(query, parameters);
            foreach (DataRow row in dt.Rows)
            {
                list.Add(new Lookup
                {
                    lookup_id = Convert.ToInt32(row["lookup_id"]),
                    lookup_type = row["lookup_type"].ToString(),
                    lookup_value = row["lookup_value"].ToString()
                });
            }
            return list;
        }
    }
}
